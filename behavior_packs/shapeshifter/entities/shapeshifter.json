{
  "format_version": "1.0.0",
  "minecraft:entity": {
    "description": {
      "identifier": "shapeshifter:shapeshift_player",
      "is_spawnable": false,
      "is_summonable": false,
      "is_experimental": false
    },
    "component_groups": {
      "shapeshifter:block_form": {
        "minecraft:scale": {
          "value": 0.5
        },
        "minecraft:collision_box": {
          "width": 0.6,
          "height": 0.6
        }
      },
      "shapeshifter:entity_form": {
        "minecraft:scale": {
          "value": 1.0
        }
      },
      "shapeshifter:human_form": {
        "minecraft:scale": {
          "value": 1.0
        },
        "minecraft:collision_box": {
          "width": 0.6,
          "height": 1.8
        }
      }
    },
    "components": {
      "minecraft:type_family": {
        "family": ["player"]
      },
      "minecraft:health": {
        "value": 20,
        "max": 20
      }
    },
    "events": {
      "shapeshifter:transform_into_block": {
        "add": {
          "component_groups": ["shapeshifter:block_form"]
        },
        "remove": {
          "component_groups": ["shapeshifter:entity_form", "shapeshifter:human_form"]
        }
      },
      "shapeshifter:transform_into_entity": {
        "add": {
          "component_groups": ["shapeshifter:entity_form"]
        },
        "remove": {
          "component_groups": ["shapeshifter:block_form", "shapeshifter:human_form"]
        }
      },
      "shapeshifter:revert_to_human": {
        "add": {
          "component_groups": ["shapeshifter:human_form"]
        },
        "remove": {
          "component_groups": ["shapeshifter:block_form", "shapeshifter:entity_form"]
        }
      }
    }
  }
}
